# Source
SOURCE_URL=https://example.com/api/data
SOURCE_API_KEY=your_api_key_here

# API behaviour
# PAGINATION_STYLE=auto
# AUTH_METHOD=bearer
# AUTH_PARAM_NAME=api_key
# DATA_KEY=
# CURSOR_KEY=
# TOTAL_KEY=
# RATE_LIMIT_DELAY=0

# MongoDB
# MONGO_DB and MONGO_COLLECTION are auto-derived from SOURCE_URL if omitted
# e.g. api.nasa.gov/planetary/apod -> db: nasa_etl, collection: apod
MONGO_URI=mongodb://mongo:27017
# MONGO_DB=custom_db_name
# MONGO_COLLECTION=custom_collection

# Pipeline
BATCH_SIZE=500
LOG_LEVEL=INFO
MAX_RETRIES=3
RETRY_DELAY=2
